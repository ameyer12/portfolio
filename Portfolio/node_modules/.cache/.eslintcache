\"right-bullet\">» Express.js</span>\n            <br></br>\n            » HTML <span className=\"right-bullet\">» CSS</span>\n            <br></br>\n            » Bootstrap <span className=\"right-bullet\">» Figma</span>\n            <br></br>\n            » Git <span className=\"right-bullet\">» GitHub</span>\n            </p>\n      </div>\n    )\n  }\n\nexport default About;","/Users/AustinTheGOAT/Portfolio/src/components/Project1.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/Navbar.js",["81","82","83"],[],"import React from \"react\";\nimport \"./navbar.css\"\nimport logoImage from \"./Austin Meyer Logo.png\";\nimport resumePDF from \"./Austin Meyer Resume - 2022.pdf\"\n\nfunction Navbar({navigate}) {\n  return (\n    <nav class=\"navbar navbar-expand-lg navbar-light\">\n        <a id=\"navbar-brand-name\" class=\"navbar-brand\" href=\"/\"><img src={logoImage} alt=\"Austin Meyer Logo\" width=\"80\" height=\"80\"/></a>\n            <button id=\"mobile-button\" class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-target=\"#navbarNav\" aria-controls=\"navbarNav\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n                <span class=\"navbar-toggler-icon\"></span>\n            </button>\n        <div class=\"collapse navbar-collapse\" id=\"navbarNav\">\n            <ul class=\"navbar-nav\">\n            <li class=\"nav-item active\">\n                <a id=\"about-link\" class=\"nav-link\" href=\"#\">About</a>\n            </li>\n            <li class=\"nav-item\">\n                <a id=\"projects-link\" class=\"nav-link\" href=\"#\">Projects</a>\n            </li>\n            <li class=\"nav-item\">\n                <a id=\"contact-link\" class=\"nav-link\" href=\"#\">Contact</a>\n            </li>\n            <a id=\"resume-button\" type=\"button\" class=\"btn btn-outline-dark btn-sm\" href={resumePDF} target=\"_blank\" rel=\"noreferrer\">Resume</a>\n            </ul>\n        </div>\n    </nav>\n  )\n}\n\nexport default Navbar;","/Users/AustinTheGOAT/Portfolio/src/components/Project5.js",[],["84"],"/Users/AustinTheGOAT/Portfolio/src/components/Project4.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/Project2.js",[],[],{"ruleId":"85","severity":1,"message":"86","line":2,"column":8,"nodeType":"87","messageId":"88","endLine":2,"endColumn":12},{"ruleId":"89","severity":1,"message":"90","line":15,"column":13,"nodeType":"91","endLine":15,"endColumn":107},{"ruleId":"92","severity":1,"message":"93","line":16,"column":17,"nodeType":"91","endLine":16,"endColumn":62},{"ruleId":"92","severity":1,"message":"93","line":19,"column":17,"nodeType":"91","endLine":19,"endColumn":65},{"ruleId":"92","severity":1,"message":"93","line":22,"column":17,"nodeType":"91","endLine":22,"endColumn":64},{"ruleId":"92","severity":1,"message":"94","line":16,"column":21,"nodeType":"91","endLine":22,"endColumn":22,"suppressions":"95"},"no-unused-vars","'swal' is defined but never used.","Identifier","unusedVar","jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","JSXOpeningElement","jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md",["96"],{"kind":"97","justification":"98"},"directive",""]