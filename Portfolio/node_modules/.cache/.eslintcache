unt":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"74","messages":"75","suppressedMessages":"76","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"77","messages":"78","suppressedMessages":"79","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/AustinTheGOAT/Portfolio/src/index.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/App.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/index.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/Home.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/Sidebar.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/Projects.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/Project3.js",["80"],[],"import React from \"react\";\nimport swal from 'sweetalert';\nimport './project3.css';\n\nfunction Project3() {\n    return (\n      <div id=\"project3-body\" className=\"animate__animated animate__fadeInDown\">\n          <h4>The Closet</h4>\n          <p id=\"project3-description\">\n            A full stack e-commerce clothing application. This project was developed as a group project, utilizing agile devlopment practices. Tech stack: REACT, HTML/CSS, Bootstrap, Node, Express, PostgreSQL, Render.\n          </p>\n          <div>\n            <ul id=\"project3-links-ul\">\n                <li id=\"project3-link1\">\n                    <a \n                        id=\"project3-link1\"\n                        onClick={() => {\n                            swal(\"Development still in progress. Check back later!\")\n                        }\n                    }\n                    >View Site</a></li>\n                <li id=\"project3-link2\"><a id=\"project3-link2\" href=\"https://github.com/Igein/grace-shopper-starter\">GitHub</a></li>\n            </ul>\n          </div>\n      </div>\n    )\n  }\n\nexport default Project3;","/Users/AustinTheGOAT/Portfolio/src/components/Contact.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/RightSideBar.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/About.js",["81"],[],"import React from \"react\";\nimport './about.css'\n\nfunction About() {\n    return (\n      <div id='about-body' >\n          <h3>About Me</h3>\n          <p className=\"about-me-paragraph\">My name is Austin Meyer. I’m 23 years old, and I live in Fort Worth, Texas.\n            <br></br>\n            I attended The University of Texas at Austin and received my Bachelor of Arts in English\n            <br></br>\n            in 2021. Since then, I've been working full-time while attending Fullstack Academy\n            <br></br>\n            to learn web development and UI design. </p>\n            <img id=\"about-image\" src=\"https://i.postimg.cc/J0XB42wS/IMG-0955.jpg\" alt=\"Graduation Photo\"></img>\n          <h3 className=\"about-skills-section\">Skills</h3>\n          <p className=\"skills-bullets\">\n            » JavaScript (ES6+) <span className=\"right-bullet\">» React</span>\n            <br></br>\n            » Node.js <span className=\"right-bullet\">» Express.js</span>\n            <br></br>\n            » HTML <span className=\"right-bullet\">» CSS</span>\n            <br></br>\n            » Bootstrap <span className=\"right-bullet\">» Figma</span>\n            <br></br>\n            » Git <span className=\"right-bullet\">» GitHub</span>\n            </p>\n      </div>\n    )\n  }\n\nexport default About;","/Users/AustinTheGOAT/Portfolio/src/components/Project1.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/Navbar.js",["82","83","84"],[],"import React from \"react\";\nimport \"./navbar.css\"\nimport logoImage from \"./Austin Meyer Logo.png\";\nimport resumePDF from \"./Austin Meyer Resume - 2022.pdf\"\n\nfunction Navbar({navigate}) {\n  return (\n    <nav class=\"navbar navbar-expand-lg navbar-light\">\n        <a id=\"navbar-brand-name\" class=\"navbar-brand\" href=\"/\"><img src={logoImage} alt=\"Austin Meyer Logo\" width=\"80\" height=\"80\"/></a>\n            <button id=\"mobile-button\" class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-target=\"#navbarNav\" aria-controls=\"navbarNav\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n                <span class=\"navbar-toggler-icon\"></span>\n            </button>\n        <div class=\"collapse navbar-collapse\" id=\"navbarNav\">\n            <ul class=\"navbar-nav\">\n            <li class=\"nav-item active\">\n                <a id=\"about-link\" class=\"nav-link\" href=\"#\">About</a>\n            </li>\n            <li class=\"nav-item\">\n                <a id=\"projects-link\" class=\"nav-link\" href=\"#\">Projects</a>\n            </li>\n            <li class=\"nav-item\">\n                <a id=\"contact-link\" class=\"nav-link\" href=\"#\">Contact</a>\n            </li>\n            <a id=\"resume-button\" type=\"button\" class=\"btn btn-outline-dark btn-sm\" href={resumePDF} target=\"_blank\" rel=\"noreferrer\">Resume</a>\n            </ul>\n        </div>\n    </nav>\n  )\n}\n\nexport default Navbar;","/Users/AustinTheGOAT/Portfolio/src/components/Project5.js",[],["85"],"/Users/AustinTheGOAT/Portfolio/src/components/Project4.js",[],[],"/Users/AustinTheGOAT/Portfolio/src/components/Project2.js",[],[],{"ruleId":"86","severity":1,"message":"87","line":15,"column":21,"nodeType":"88","endLine":21,"endColumn":22},{"ruleId":"89","severity":1,"message":"90","line":15,"column":13,"nodeType":"88","endLine":15,"endColumn":107},{"ruleId":"86","severity":1,"message":"91","line":16,"column":17,"nodeType":"88","endLine":16,"endColumn":62},{"ruleId":"86","severity":1,"message":"91","line":19,"column":17,"nodeType":"88","endLine":19,"endColumn":65},{"ruleId":"86","severity":1,"message":"91","line":22,"column":17,"nodeType":"88","endLine":22,"endColumn":64},{"ruleId":"86","severity":1,"message":"87","line":16,"column":21,"nodeType":"88","endLine":22,"endColumn":22,"suppressions":"92"},"jsx-a11y/anchor-is-valid","The href attribute is required for an anchor to be keyboard accessible. Provide a valid, navigable address as the href value. If you cannot provide an href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md","JSXOpeningElement","jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/jsx-eslint/eslint-plugin-jsx-a11y/blob/HEAD/docs/rules/anchor-is-valid.md",["93"],{"kind":"94","justification":"95"},"directive",""]